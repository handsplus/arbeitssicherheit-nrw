# Resend (E-Mails: Kontakt, Beratung, Besuch-Benachrichtigung)
# Hol dir einen API-Key unter https://resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxx

# Optional: Eigener Absender (sonst wird onboarding@resend.dev genutzt)
# Nach Domain-Verifizierung in Resend z.B.:
# RESEND_FROM=Arbeitssicherheit.nrw <kontakt@arbeitssicherheit.nrw>

# Optional: Formspree für „Beratung buchen“ – wenn gesetzt, geht das Formular an Formspree statt an Resend.
# Form-ID aus der Formspree-URL: https://formspree.io/f/XXXXX → nur XXXXX eintragen
# NEXT_PUBLIC_FORMSPREE_BERATUNG_ID=xxxxx

# Optional: Formspree für „Nachricht senden“ (Kontaktformular). Eigene Form-ID oder gleiche wie Beratung.
# NEXT_PUBLIC_FORMSPREE_KONTAKT_ID=xxxxx

# Optional: Google Search Console – Meta-Tag „google-site-verification“ (Sichtbarkeit in der Suche)
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
